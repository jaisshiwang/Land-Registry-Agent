# Copy this file to .env and provide a key with access to the chosen models.
# Never commit the populated .env file.
OPENAI_API_KEY=
OPENAI_INTENT_MODEL=gpt-4o-mini
OPENAI_DRAFT_MODEL=gpt-4o-mini

# HM Land Registry sources
LAND_REGISTRY_SPARQL_URL=https://landregistry.data.gov.uk/landregistry/query
HPI_REGION_BASE_URL=https://landregistry.data.gov.uk/data/hpi/region

# Bounded HTTP and pagination policy
HTTP_TIMEOUT_SECONDS=60
HTTP_MAX_RETRIES=2
QUERY_PAGE_SIZE=1000
QUERY_MAX_PAGES=20
CACHE_TTL_SECONDS=3600

# Local persistence
CHECKPOINT_DB_PATH=data/checkpoints.sqlite3
REPORTS_DB_PATH=data/reports.sqlite3
CACHE_DIRECTORY=data/cache

# Deterministic analytical thresholds
MINIMUM_LOCAL_TRANSACTIONS=10
MINIMUM_STREET_TRANSACTIONS=3
MAXIMUM_CORRECTIVE_REDRAFTS=1

# Restrict LangGraph checkpoint deserialization.
LANGGRAPH_STRICT_MSGPACK=true

# Demonstration identity — not authentication
DEMO_USER_ID=demo-user-001
DEMO_USER_DISPLAY_NAME=Demo User
